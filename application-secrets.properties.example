# Copy this file to application-secrets.properties (project root).
# The real application-secrets.properties is gitignored.

# Spring AI — OpenAI (powers tool calling + audio transcription)
spring.ai.openai.api-key=sk-REPLACE_ME

# Other major LLM providers (reserved for integrations)
# Anthropic
app.anthropic.api-key=

# Google AI (Gemini)
app.google.ai.api-key=

# Azure OpenAI
app.azure.openai.api-key=
app.azure.openai.endpoint=

# Cohere
app.cohere.api-key=

# Mistral
app.mistral.api-key=

# Groq
app.groq.api-key=

# Perplexity
app.perplexity.api-key=

# xAI (Grok)
app.xai.api-key=

# Together AI
app.together.api-key=

# OpenRouter
app.openrouter.api-key=

# Fish Audio (TTS) — https://fish.audio — model id from ?modelId=... in app URL or /m/<id>
fish.audio.api.key=
fish.audio.reference.id=

# Web search APIs (optional — https://serper.dev / https://serpapi.com)
serper.api.key=
serpapi.api.key=

# Google account integrations — same OAuth Web client as TelliChat (copy these keys from tellichat secrets).
# In Google Cloud, add Mins Bot redirect in addition to TelliChat’s:
#   http://127.0.0.1:8765/api/integrations/google/oauth2/callback
spring.security.oauth2.client.registration.google.client-id=
spring.security.oauth2.client.registration.google.client-secret=
# Optional fallback if Spring keys above are empty:
# app.integrations.google.client-id=
# app.integrations.google.client-secret=

# Optional: override server port locally
# server.port=8765
